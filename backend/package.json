    "seed": "node src/utils/seed.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "mongoose": "^8.5.0",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "winston": "^3.13.0",
    "cookie-parser": "^1.4.6",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "nodemailer": "^6.9.14",
    "razorpay": "^2.9.4",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^2.3.0",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "cross-env": "^7.0.3",
    "mongodb-memory-server": "^9.4.0"

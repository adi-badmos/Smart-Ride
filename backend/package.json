{
  "name": "smart-ride-backend",
  "version": "1.0.0",
  "description": "Smart Ride - Monthly Pickup & Drop Subscription Platform API",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",

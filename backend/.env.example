NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/smart-ride?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# CORS — in production this MUST be your real deployed frontend origin
# (e.g. https://smart-ride.vercel.app), never http://localhost:5173 and
# never a wildcard. See app.js for why a wildcard + credentials:true
# silently breaks every cookie-bearing request.
CORS_ORIGIN=http://localhost:5173

# Seed script overrides (optional — sensible defaults are used if unset)
SEED_ADMIN_EMAIL=admin@smartride.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Email
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@smartride.com